{
  "name": "supercharged",
  "description": "A comprehensive set of scripts for setting up a developer-friendly macOS environment",
  "version": "1.0.0",
  "scripts": {
    "help": "./scripts/help.sh",
    "setup": "npm run setup:profile && ./scripts/mac.sh && npm run validate",
    "setup:profile": "./scripts/setup-profile.sh",
    "update": "./scripts/backup-claude.sh && npm run setup:profile && ./scripts/update.sh",
    "update:dry-run": "./scripts/update.sh --dry-run",
    "update:brew": "npm run setup:profile && ./scripts/update.sh --skip-asdf --skip-zsh --skip-npm --skip-pip",
    "update:asdf": "npm run setup:profile && ./scripts/update.sh --skip-brew --skip-cask --skip-zsh --skip-npm --skip-pip",
    "update:zsh": "./scripts/update.sh --skip-brew --skip-cask --skip-asdf --skip-npm --skip-pip",
    "update:npm": "./scripts/update.sh --skip-brew --skip-cask --skip-asdf --skip-zsh --skip-pip",
    "update:pip": "./scripts/update.sh --skip-brew --skip-cask --skip-asdf --skip-zsh --skip-npm",
    "validate": "cd scripts && ./utils.sh validate",
    "restore": "./scripts/restore.sh",
    "backup:claude": "./scripts/backup-claude.sh",
    "restore:claude": "./scripts/restore-claude.sh",
    "restore:claude:force": "./scripts/restore-claude.sh --force",
    "lint": "shellcheck --shell=bash scripts/*.sh 2>&1 | grep -v SC1071 || true",
    "test": "bats tests/**/*.bats",
    "test:watch": "watch 'npm test' tests scripts",
    "test:claude": "bats tests/claude/*.bats",
    "test:utils": "bats tests/utils/*.bats",
    "test:mac": "bats tests/mac/*.bats",
    "test:update": "bats tests/update/*.bats",
    "test:setup": "bats tests/setup/*.bats",
    "pretest": "command -v bats >/dev/null || (echo '❌ bats not found. Install with: brew install bats-core' && exit 1)"
  }
}
