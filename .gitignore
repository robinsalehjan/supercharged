# Prevent accidentally committing home directory expansions
~
~/*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log

# Backup files
*.backup
*.bak

# Node.js dependencies
node_modules/

# Claude Code project-specific settings
.claude/

# Git worktrees for isolated development
.worktrees/

