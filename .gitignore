# Prevent accidentally committing home directory expansions
~
~/*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Logs
*.log

# Backup files
*.backup
*.bak

# Node.js dependencies
node_modules/

# Claude Code project-specific settings
.claude/

# Git worktrees for isolated development
.worktrees/

# Task tracker (agent working document)
.task-tracker.md

# MCP config (machine-specific)
.mcp.json

# Husky (replaced by hookify rules)
.husky/

# Local-only plugin config (machine-specific, not committed)
claude_config/*.local.json

# Superpowers plans and specs are local-only
docs/superpowers/
# Added by code-review-graph
.code-review-graph/
