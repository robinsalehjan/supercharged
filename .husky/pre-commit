#!/bin/bash

# Security-focused pre-commit hook for personal/work machines
# This ensures no sensitive data or machine-specific paths are committed

set -e  # Exit on any error

echo "🔒 Running security checks..."

# =============================================================================
# 1. SHELLCHECK - REQUIRED (not optional)
# =============================================================================
if ! command -v shellcheck >/dev/null 2>&1; then
  echo "❌ shellcheck is REQUIRED but not installed"
  echo "   This repository runs on personal and work machines - shellcheck is mandatory"
  echo "   Install with: brew install shellcheck"
  exit 1
fi

echo "🔍 Running shellcheck on scripts..."

# Run shellcheck with specific exclusions for zsh-compatible code
if ! shellcheck --shell=bash \
  --exclude=SC1071,SC2296,SC1091,SC2155,SC2001,SC2012,SC2059,SC2034 \
  scripts/*.sh 2>&1; then
  echo "❌ shellcheck found issues - fix before committing"
  exit 1
fi

echo "✅ shellcheck passed"

# =============================================================================
# 2. SECRETS DETECTION
# =============================================================================
echo "🔍 Checking for secrets and credentials..."

# Check for common secret patterns in staged files
if git diff --cached --name-only | xargs -I {} grep -HnE \
  '(password|secret|api[_-]?key|token|credential|private[_-]?key)\s*[=:]\s*["\047][^"\047]{8,}' \
  {} 2>/dev/null | grep -v "YOUR_.*_HERE" | grep -v ".local.md" | grep -v "TEMPLATE"; then
  echo "❌ Potential secrets detected in staged files!"
  echo "   Review the matches above. If these are real secrets, DO NOT COMMIT."
  echo "   Use placeholders like: YOUR_API_KEY_HERE"
  exit 1
fi

echo "✅ No secrets detected"

# =============================================================================
# 3. HARDCODED PATHS CHECK
# =============================================================================
echo "🔍 Checking for hardcoded user paths in dotfiles..."

# Check dotfiles for hardcoded paths
DOTFILES_CHANGED=$(git diff --cached --name-only | grep "^dot_files/" || true)
if [ -n "$DOTFILES_CHANGED" ]; then
  if echo "$DOTFILES_CHANGED" | xargs grep -HnE '(/Users/[^/]+/|/home/[^/]+/)' 2>/dev/null; then
    echo "❌ Hardcoded user paths detected in dotfiles!"
    echo "   Dotfiles must be portable across machines."
    echo "   Use \$HOME instead of /Users/username/ or /home/username/"
    exit 1
  fi
fi

echo "✅ No hardcoded paths in dotfiles"

# =============================================================================
# 4. .secrets FILE CHECK
# =============================================================================
echo "🔍 Checking .secrets template..."

if git diff --cached --name-only | grep -q "^dot_files/.secrets$"; then
  # Check if .secrets has real values (non-placeholder)
  if grep -qE '^export [A-Z_]+=["'"'"'][^"'"'"'YOUR_]{8,}["'"'"']' dot_files/.secrets 2>/dev/null; then
    echo "❌ .secrets appears to contain real credentials!"
    echo "   .secrets should only contain placeholders like: YOUR_API_KEY_HERE"
    echo "   Real secrets should NEVER be committed."
    exit 1
  fi
fi

echo "✅ .secrets template is safe"

# =============================================================================
# 5. CLAUDE CONFIG SANITIZATION CHECK
# =============================================================================
echo "🔍 Checking Claude config backups for work data..."

if git diff --cached --name-only | grep -q "^claude_config/"; then
  # Check for common work marketplace identifiers
  if git diff --cached -- claude_config/ | grep -iE '\+.*"(vend|work|company|corp|internal).*plugins"'; then
    echo "⚠️  WARNING: Potential work-related Claude plugins detected!"
    echo "   Review claude_config/ changes to ensure no work marketplaces are included."
    echo "   The backup script should sanitize these automatically."
    echo ""
    read -rp "Continue anyway? [y/N]: " response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
      exit 1
    fi
  fi
fi

echo "✅ Claude config looks clean"

# =============================================================================
# 6. FILE SIZE CHECK (prevent accidental large file commits)
# =============================================================================
echo "🔍 Checking for large files..."

MAX_FILE_SIZE=1048576  # 1MB in bytes

git diff --cached --name-only | while read -r file; do
  if [ -f "$file" ]; then
    size=$(wc -c < "$file")
    if [ "$size" -gt "$MAX_FILE_SIZE" ]; then
      echo "❌ Large file detected: $file ($(($size / 1024))KB)"
      echo "   Files over 1MB should not be committed to this repository."
      echo "   Consider using .gitignore or Git LFS."
      exit 1
    fi
  fi
done

echo "✅ No large files detected"

# =============================================================================
# SUMMARY
# =============================================================================
echo ""
echo "✅ All security checks passed!"
echo "   Safe to commit to personal and work machines."
echo ""

# =============================================================================
# 7. BATS TESTS (if available)
# =============================================================================
# Run BATS tests if test files exist
if [ -d "tests" ] && command -v bats >/dev/null 2>&1; then
  echo "🧪 Running tests..."
  npm test || {
    echo "❌ Tests failed. Fix issues before committing."
    echo "   Tip: Use '--no-test' in commit message to skip tests during rapid iteration"
    exit 1
  }
fi
