#!/bin/zsh
# Secrets and sensitive environment variables
# This file should NOT be committed to version control
# Copy this to ~/.secrets and customize with your actual values

# AWS Credentials
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export AWS_DEFAULT_REGION="us-east-1"

# GitHub Token
# export GITHUB_TOKEN=""
# export GITHUB_USERNAME=""

# Google Cloud
# export GCLOUD_PROJECT_ID=""
# export GOOGLE_APPLICATION_CREDENTIALS="$HOME/.config/gcloud/service-account.json"

# Docker Hub
# export DOCKER_USERNAME=""
# export DOCKER_PASSWORD=""

# API Keys
# export OPENAI_API_KEY=""
# export ANTHROPIC_API_KEY=""

# Database Credentials
# export DATABASE_URL=""
# export POSTGRES_PASSWORD=""
# export MONGODB_URI=""

# Slack/Discord Webhooks
# export SLACK_WEBHOOK_URL=""
# export DISCORD_WEBHOOK_URL=""

# Custom Environment Variables
# export MY_SECRET_KEY=""
# export MY_API_ENDPOINT=""

# Claude Code / MCP Server Keys
# These are sourced by restore-claude.sh to inject into ~/.claude/settings.json
# GITHUB_PERSONAL_ACCESS_TOKEN: global Claude Code env (git operations, hooks)
# STITCH_API_KEY: injected into Stitch MCP server env via mcp_servers.json
# export GITHUB_PERSONAL_ACCESS_TOKEN=""
# export STITCH_API_KEY=""

# Supercharged Options
# Set to 1 to auto-start Colima (Docker runtime) on shell load
# export SUPERCHARGED_COLIMA_AUTOSTART=1
