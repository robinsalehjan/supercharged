# Supercharged Development Tool Versions
# Format: <plugin> <version>
# Pin to stable versions with minimum requirements for compatibility

# Development Languages
# Node.js - LTS version, minimum 20.0.0 for modern features
nodejs 24.14.1

# Python - Latest stable, minimum 3.10.0 for type hints and match statements
python 3.14.3

# Ruby - Stable version, minimum 2.7.0 for pattern matching
ruby 3.4.9

# Package Managers
# Bundler - Ruby package manager, minimum 2.2.0 for lockfile improvements
bundler 4.0.10

# Cloud and DevOps Tools
# Google Cloud SDK - Latest stable, minimum 400.0.0 for gke-gcloud-auth-plugin
gcloud 564.0.0

# Firebase CLI - Latest stable, minimum 12.0.0 for modern deployment features
firebase 15.14.0

# JVM toolchain (java, kotlin) is opt-in via INSTALL_JVM_TOOLS=Y.
# By default setup resolves `asdf latest java openjdk` and `asdf latest kotlin`.
# To pin a specific version on a work machine, add lines like:
#   java openjdk-25.0.2
#   kotlin 2.3.20

# Additional tools can be added here
# Example:
# terraform 1.5.7
# kubectl 1.28.0
