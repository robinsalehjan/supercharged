{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "hookify@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "printf \"\u001b[36m%s\u001b[0m:\u001b[34m%s\u001b[0m\" \"$USER\" \"$(basename $PWD)\""
  }
}
